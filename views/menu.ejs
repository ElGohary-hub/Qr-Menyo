<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>المنيو</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>.product-img { height: 200px; object-fit: cover; border-radius: 8px 8px 0 0; }</style>
</head>
<body class="bg-light">
    <div class="container mt-4">
        <h1 class="text-center text-danger fw-bold mb-4">منيو <%= restaurantName %></h1>
        <div class="row">
            <% if (items.length === 0) { %>
                <p class="text-center">المنيو فارغ حالياً.</p>
            <% } else { %>
                <% items.forEach(function(item) { %>
                    <div class="col-12 col-md-4 mb-4">
                        <div class="card shadow-sm">
                            <img src="<%= item.image %>" class="card-img-top product-img">
                            <div class="card-body">
                                <h5><%= item.name %></h5>
                                <p><%= item.desc %></p>
                                <h5 class="text-success"><%= item.price %> ج.م</h5>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </div>
</body>
</html>

