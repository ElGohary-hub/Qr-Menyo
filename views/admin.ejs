<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة التحكم</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <h2 class="text-center mb-4">لوحة تحكم: <%= restaurantName %></h2>
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card p-4 shadow-sm">
                    <h4>إضافة منتج</h4>
                    <form action="/admin/add" method="POST">
                        <input type="text" name="name" class="form-control mb-2" placeholder="الاسم" required>
                        <input type="text" name="desc" class="form-control mb-2" placeholder="الوصف" required>
                        <input type="number" name="price" class="form-control mb-2" placeholder="السعر" required>
                        <input type="url" name="image" class="form-control mb-3" placeholder="رابط الصورة" required>
                        <button type="submit" class="btn btn-primary w-100">إضافة</button>
                    </form>
                </div>
            </div>
            <div class="col-md-6 mb-4 text-center">
                <div class="card p-4 shadow-sm">
                    <h4>الـ QR Code الخاص بك</h4>
                    <img src="<%= qrImage %>" class="img-fluid w-50 mx-auto">
                    <a href="<%= menuUrl %>" target="_blank" class="btn btn-success mt-3">عرض المنيو</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
